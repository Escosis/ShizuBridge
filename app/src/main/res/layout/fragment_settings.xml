<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clipToPadding="false"
    android:paddingHorizontal="20dp"
    android:fillViewport="true">

    <!-- 唯一直接子元素 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 主题卡片 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theme_mode"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <RadioGroup
                android:id="@+id/themeRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/radioFollowSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/theme_follow_system"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/radioLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:text="@string/theme_light"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/radioDark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="?attr/colorPrimary"
                    android:text="@string/theme_dark"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />

            </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

        <!-- 语言设置卡片 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/language"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <RadioGroup
                android:id="@+id/languageRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <RadioButton
                    android:id="@+id/radioLangFollowSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/language_follow_system"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/radioLangChinese"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/language_chinese"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />

                <RadioButton
                    android:id="@+id/radioLangEnglish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/language_english"
                    android:buttonTint="?attr/colorPrimary"
                    android:textColor="?attr/colorOnSurface"
                    android:padding="12dp" />
            </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 关于卡片 ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 应用名称 + 版本号 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_name"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <!-- 功能简介 -->
                <TextView
                    android:id="@+id/tvAboutDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_description"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="8dp" />

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="?attr/colorOutline"
                    android:layout_marginVertical="12dp" />

                <!-- GitHub 链接 -->
                <LinearLayout
                    android:id="@+id/llGitHub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/github_repo"
                        android:textSize="16sp"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/baseline_open_in_new_24"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 底部占位，确保最后一项内容不被导航栏遮挡 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:visibility="invisible" />

    </LinearLayout>
</ScrollView>