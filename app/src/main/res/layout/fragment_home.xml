<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 状态卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EFF6FF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="服务状态"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正在检测..."
                    android:textSize="16sp"
                    android:textColor="#1E40AF"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="注：应用启动后约30秒连接才会就绪，可打开Shizuku关闭权限重新授权以跳过等待"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 操作按钮区 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRequestPermission"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="申请 Shizuku 权限"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"
            app:cornerRadius="12dp"
            app:backgroundTint="#2563EB"
            android:enabled="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestCommand"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="测试：列出目标目录"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"
            app:cornerRadius="12dp"
            app:backgroundTint="#10B981"
            android:enabled="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenShizuku"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="打开 Shizuku 管理权限"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"
            app:cornerRadius="12dp"
            app:strokeColor="#2563EB"
            android:textColor="#2563EB"/>

        <!-- 结果展示区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="执行结果"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F3F4F6">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:text="等待执行..."/>
            </ScrollView>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>